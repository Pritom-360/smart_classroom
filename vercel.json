{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/reset-password",
      "destination": "/competition/reset-password",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/competition/(.*)",
      "destination": "/competition/index.html"
    },
    {
      "source": "/competition",
      "destination": "/competition/index.html"
    }
  ]
}
